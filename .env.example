# ─── CIAlert — Configuration ───────────────────
# Copie ce fichier en .env et remplis tes clés

# ── IA Provider ──────────────────────────────
# Choix : groq | gemini | claude
AI_PROVIDER=groq

# Groq (gratuit) → https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192

# Gemini (gratuit) → https://aistudio.google.com
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Claude (payant) → https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Bot Telegram ─────────────────────────────
# Crée ton bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC...

# ── Serveur ──────────────────────────────────
PORT=8000
